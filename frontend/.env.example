# Phoenix Frontend Environment Variables
# ──────────────────────────────────────
# Backend API URL — must match APP_URL in backend
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# App name (optional)
NEXT_PUBLIC_APP_NAME=Phoenix Business Suite

# Optional: Sentry for frontend error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
