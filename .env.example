# ══════════════════════════════════════════════════════════════
# Phoenix Business Suite v1.4 — Root Environment Example
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# PostgreSQL connection string (Supabase, Render Postgres, etc.)
DATABASE_URL=postgresql://postgres:yourpassword@db.project.supabase.co:5432/postgres

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=change_me_to_a_64_char_plus_random_string_openssl_rand_hex_64
JWT_EXPIRES_IN=8h

# Application URLs (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
APP_URL=https://your-api.onrender.com
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# Optional: Sentry DSN for error monitoring
# SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
