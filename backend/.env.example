# Phoenix Backend Environment Variables
# ─────────────────────────────────────
NODE_ENV=production
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:password@host:5432/dbname

# Auth — generate: openssl rand -hex 64
JWT_SECRET=minimum_32_chars_use_64_for_production
JWT_EXPIRES_IN=8h

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL=https://your-app.vercel.app,http://localhost:3000

# App public URL (used in PDF QR codes)
APP_URL=https://your-api.onrender.com

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Optional Monitoring
# SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
