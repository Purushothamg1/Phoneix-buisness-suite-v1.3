{
  "name": "phoenix-backend",
  "version": "1.4.0",
  "description": "Phoenix Business Suite \u2014 Backend API v1.4",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc && npm run postbuild",
    "postbuild": "echo 'Build complete'",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:seed": "ts-node src/config/seed.ts",
    "test": "jest --passWithNoTests --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "prestart": "node -e \"if(!process.env.DATABASE_URL||!process.env.JWT_SECRET){console.error('[FATAL] DATABASE_URL and JWT_SECRET must be set');process.exit(1)}\""
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "@sentry/node": "^8.0.0",
    "bcrypt": "^5.1.1",
    "celebrate": "^15.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/pdfkit": "^0.13.3",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^2.0.0",
    "@types/uuid": "^9.0.7",
    "jest": "^29.0.0",
    "prisma": "^5.7.0",
    "supertest": "^6.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "@typescript-eslint/parser": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "eslint": "^8.57.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "@/(.*)": "<rootDir>/src/$1"
    },
    "forceExit": true
  },
"prisma": {
  "seed": "node --loader ts-node/esm src/config/seed.ts"
}
}
